# Copy to .env and set your key for real answers.

# --- OpenAI (required for real answers) ---
OPENAI_API_KEY=

# Provider selection: auto | openai | local
#   auto  -> use OpenAI when OPENAI_API_KEY is set, otherwise the local
#            deterministic provider (so the app + tests run with no key)
EMBEDDINGS_PROVIDER=auto
LLM_PROVIDER=auto

OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# --- Retrieval / chunking ---
CHUNK_SIZE=800
CHUNK_OVERLAP=120
TOP_K=4
RELEVANCE_THRESHOLD=0.15
